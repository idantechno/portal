# Copy to .env and edit as needed.

# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# --- Auth ---
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Anthropic ---
ANTHROPIC_API_KEY=
# Default model used by the agent worker.
AGENT_MODEL=claude-sonnet-4-6

# --- Encryption ---
# 32-byte key, base64-encoded. Used to encrypt sensitive per-business secrets
# (WhatsApp access tokens) at rest in Postgres.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# --- Meta / WhatsApp Cloud API (SaaS-shaped: one app, one webhook for all businesses) ---
# Our Meta App credentials. Customers connect their WABA to us via Embedded
# Signup; they never touch developers.facebook.com.
META_APP_ID=
META_APP_SECRET=
# Static verify token Meta echoes during webhook verification. Generate with:
# openssl rand -hex 32
META_WEBHOOK_VERIFY_TOKEN=
META_GRAPH_API_VERSION=v21.0
# The Embedded Signup "configuration ID" Meta issues for our WABA Tech Provider
# flow. Passed to FB.login on the frontend.
META_EMBEDDED_SIGNUP_CONFIG_ID=

# --- Business storage ---
# Path inside the api/worker containers. A host directory is bind-mounted here
# in docker-compose; it holds /{businessId}/<context files> per tenant.
BUSINESSES_DIR=/data/businesses
# Host-side directory mounted into the containers. Created on first `make dev`.
BUSINESSES_HOST_DIR=./.data/businesses

# --- Postgres ---
DB_HOST=postgres
DB_PORT=5432
# Host-side port mapping (change if 5432 is already in use locally — e.g. 5433)
DB_HOST_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=portal
# Auto-create schema from entities (dev only — use migrations in prod)
DB_SYNCHRONIZE=true
DB_LOGGING=false

# --- Redis (BullMQ queues + Socket.IO adapter) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379

# --- Compose host-side port overrides ---
# Dev — host ports for the dev stack. Bump these if you have collisions.
BACKEND_HOST_PORT=3000
BACKEND_DEBUG_HOST_PORT=9229
FRONTEND_HOST_PORT=5173
# Prod
FRONTEND_PORT=8080
ADMINER_PORT=8081

# --- Frontend (build-time) ---
VITE_API_URL=/api
VITE_WS_URL=/
# Meta App ID (public) + Embedded Signup config ID, consumed by the FB JS SDK.
VITE_META_APP_ID=
VITE_META_EMBEDDED_SIGNUP_CONFIG_ID=
VITE_META_GRAPH_API_VERSION=v21.0
