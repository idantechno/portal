# Copy to .env and edit as needed.

# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# --- Postgres ---
DB_HOST=postgres
DB_PORT=5432
# Host-side port mapping (change if 5432 is already in use locally — e.g. 5433)
DB_HOST_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=portal
# Auto-create schema from entities (dev only — use migrations in prod)
DB_SYNCHRONIZE=true
DB_LOGGING=false

# --- Compose host-side port overrides ---
# Dev — host ports for the dev stack. Bump these if you have collisions.
BACKEND_HOST_PORT=3000
BACKEND_DEBUG_HOST_PORT=9229
FRONTEND_HOST_PORT=5173
# Prod
FRONTEND_PORT=8080
ADMINER_PORT=8081

# --- Frontend (build-time) ---
VITE_API_URL=/api
